// Prisma Schema for Shizenhabu-CRM
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  ADMIN
  LEADER
  MEMBER
  PACKER
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum OrderStatus {
  PACKED
  PAID
  COD
  RETURNED
  CANCELLED
  PENDING
  OTHER
}

enum NotificationType {
  SUCCESS
  INFO
  WARNING
  ERROR
}

enum MissionStatus {
  ACTIVE
  ENDED
}

// SHEET       = ลงผ่าน Google Sheet (ลูกค้าใหม่ — Acquisition team)
// CRM_REORDER = ลงผ่านเว็บ CRM โดยตรง (รีออเดอร์ลูกค้าเก่า — Retention team)
enum OrderSource {
  SHEET
  CRM_REORDER
}

// PENDING  = สร้างใน CRM แล้ว แต่ยังไม่ได้ส่งไป Sheet
// SYNCED   = ส่ง webhook ไป Apps Script สำเร็จ — packer เห็นใน Sheet แล้ว
// FAILED   = ส่งล้มเหลว — รอ retry
// NA       = ไม่ต้อง sync (ออเดอร์ที่มาจาก Sheet อยู่แล้ว)
enum SyncStatus {
  NA
  PENDING
  SYNCED
  FAILED
}

model SheetTeam {
  id        String   @id
  name      String
  color     String?
  leaderId  String?
  createdAt DateTime @default(now())

  members  SheetUser[]
  missions SheetMission[]
  orders   SheetOrder[]

  @@map("sheet_teams")
}

model SheetUser {
  id           String     @id
  employeeId   String?    @unique
  fullName     String
  role         UserRole   @default(MEMBER)
  email        String?
  phone        String?
  idCard       String?
  photoUrl     String?
  /// bcrypt hash — null = user ยังไม่ได้ตั้งรหัส
  password     String?
  /// timestamp ตอนผู้ใช้เปลี่ยนรหัสครั้งล่าสุด
  passwordChangedAt  DateTime?
  monthlySales Decimal?   @default(0)
  isActive     UserStatus @default(ACTIVE)
  teamId       String?

  team          SheetTeam?          @relation(fields: [teamId], references: [id])
  orders        SheetOrder[]        @relation("SalesRepOrders")
  notifications SheetNotification[]
  followUps     CrmFollowUp[]
  assignedTasks CustomerTask[]      @relation("AssignedTasks")
  createdTasks  CustomerTask[]      @relation("CreatedTasks")

  @@index([teamId])
  @@map("sheet_users")
}

model SheetOrder {
  id              String      @id
  date            DateTime?
  customerName    String?
  address         String?
  phone           String?
  productsJson    Json?
  totalPrice      Decimal?    @default(0)
  status          OrderStatus @default(PENDING)
  paymentProofUrl String?
  salesRepId      String?
  salesRepName    String?
  teamId          String?
  channel         String?
  returnReason    String?
  gender          String?
  ageRange        String?
  province        String?
  isReturned      Boolean     @default(false)
  birthYear       Int?
  createdAt       DateTime    @default(now())

  // ต้นทางของออเดอร์
  source          OrderSource @default(SHEET)

  // สถานะการ sync ออเดอร์ที่สร้างใน CRM กลับไป Sheet
  // ออเดอร์ source=SHEET → syncStatus=NA (ไม่ต้อง sync ย้อน)
  // ออเดอร์ source=CRM_REORDER → เริ่มที่ PENDING → SYNCED หรือ FAILED
  syncStatus      SyncStatus  @default(NA)
  syncedAt        DateTime?
  syncError       String?
  syncAttempts    Int         @default(0)

  // user ที่กดสร้างออเดอร์ใน CRM (ต่างจาก salesRepId ที่อาจเป็นเซลส์เจ้าของลูกค้า)
  createdByUserId String?

  salesRep SheetUser? @relation("SalesRepOrders", fields: [salesRepId], references: [id])
  team     SheetTeam? @relation(fields: [teamId], references: [id])

  @@index([createdAt])
  @@index([phone])
  @@index([status])
  @@index([salesRepId])
  @@index([teamId])
  @@index([source])
  @@index([syncStatus])
  @@index([salesRepId, createdAt])
  @@index([salesRepId, phone])
  @@index([phone, createdAt])
  @@index([source, createdAt])
  @@map("sheet_orders")
}

model SheetNotification {
  id      String           @id
  userId  String?
  title   String?
  message String?
  date    DateTime?
  isRead  Boolean          @default(false)
  type    NotificationType @default(INFO)

  user SheetUser? @relation(fields: [userId], references: [id])

  @@map("sheet_notifications")
}

model SheetCustomerExtra {
  phone                String    @id
  note                 String?
  tagsJson             Json?     @default("[]")
  lastUpdated          DateTime  @default(now())

  // Health profile
  healthConditionsJson Json?     @default("[]")

  // Customer grade (A/B/C)
  grade                String?
  gradeChecklistJson   Json?
  gradeNote            String?
  gradeUpdatedAt       DateTime?

  @@map("sheet_customer_extras")
}

model Product {
  id                String   @id @default(cuid())
  name              String
  shortDesc         String?
  targetProblems    Json     @default("[]")   // string[] ปัญหาที่สินค้าแก้ได้
  contraindications Json     @default("[]")   // string[] ข้อควรระวัง
  gradeMatch        String   @default("ALL")  // "ALL" | "A" | "B" | "C" | "A,B" | "B,C"
  isActive          Boolean  @default(true)
  sortOrder         Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("products")
}

model SheetMission {
  id        String        @id
  teamId    String?
  title     String
  target    Decimal?      @default(0)
  startDate DateTime?
  endDate   DateTime?
  reward    Decimal?      @default(0)
  status    MissionStatus @default(ACTIVE)
  creatorId String?

  team SheetTeam? @relation(fields: [teamId], references: [id])

  @@map("sheet_missions")
}

// CRM Staff - แยกจาก SheetUser (sales rep) โดยสิ้นเชิง
// teamId = null → Admin (เห็นทุกทีม)
// teamId = "team-xxx" → staff ของทีมนั้น เห็นแค่ลูกค้าทีมตัวเอง
enum CrmRole {
  ADMIN
  STAFF
}

model CrmUser {
  id        String   @id @default(cuid())
  name      String
  role      CrmRole  @default(STAFF)
  teamId    String?  // null = admin ดูได้ทุกทีม
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  @@map("crm_users")
}

// บันทึกการติดตามลูกค้าของทีม CRM
enum FollowUpOutcome {
  INTERESTED       // สนใจ
  NOT_NOW          // ยังไม่พร้อม
  ORDERED          // สั่งซื้อแล้ว
  NO_ANSWER        // ไม่รับสาย
  DO_NOT_CONTACT   // ห้ามติดต่อ
  OTHER
}

// ─── Customer Task / Follow-up Todo ──────────────────────────────────────
// "งานที่ต้องทำ" กับลูกค้าแต่ละคน — เพิ่มเอง หรือ auto จาก order
enum TaskType {
  FOLLOW_UP    // ตามอาการหลังกิน
  CALL         // โทรหา
  REPEAT_BUY   // เตือนซื้อซ้ำ
  DELIVERY     // ตามของ
  CUSTOM
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  WAITING_REPLY
  DONE
  SKIPPED
}

enum TaskPriority {
  LOW
  NORMAL
  HIGH
}

model CustomerTask {
  id            String       @id @default(cuid())
  customerPhone String       // link ไป SheetOrder.phone
  title         String
  note          String?
  dueDate       DateTime
  type          TaskType     @default(CUSTOM)
  status        TaskStatus   @default(PENDING)
  priority      TaskPriority @default(NORMAL)

  assignedToId  String?      // SheetUser ที่รับผิดชอบ
  createdById   String?      // SheetUser ที่สร้าง
  orderId       String?      // ถ้า auto จาก order

  completedAt   DateTime?
  completedById String?
  resultNote    String?

  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  assignedTo SheetUser? @relation("AssignedTasks", fields: [assignedToId], references: [id])
  createdBy  SheetUser? @relation("CreatedTasks",  fields: [createdById],  references: [id])

  @@index([customerPhone])
  @@index([assignedToId, status, dueDate])
  @@index([status, dueDate])
  @@map("customer_tasks")
}

model CrmFollowUp {
  id            String          @id @default(cuid())
  customerPhone String          // เบอร์ลูกค้า (link ไป SheetOrder.phone)
  sheetUserId   String          // เซลส์/ผู้บันทึก (link ไป SheetUser.id)
  channel       String?         // CALL / LINE / SMS
  outcome       FollowUpOutcome @default(OTHER)
  note          String?
  nextActionAt  DateTime?
  createdAt     DateTime        @default(now())

  sheetUser SheetUser @relation(fields: [sheetUserId], references: [id])

  @@index([customerPhone])
  @@index([sheetUserId])
  @@map("crm_followups")
}
